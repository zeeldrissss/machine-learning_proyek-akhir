      "source": [
        "import pandas as pd\n",
        "from gnews import GNews\n",
        "from datetime import datetime, timedelta\n",
        "import time\n",
        "\n",
        "def fetch_yahoo_finance_headlines(ticker, start_date, end_date):\n",
        "    \"\"\"\n",
        "    Scrapes historical headlines specifically from Yahoo Finance via Google News.\n",
        "    Dates must be provided as tuples: (YYYY, MM, DD).\n",
        "    Batches by month to work around GNews's ~100 results-per-request cap.\n",
        "    \"\"\"\n",
        "    start_dt = datetime(*start_date)\n",
        "    end_dt = datetime(*end_date)\n",
        "\n",
        "    print(f\"Fetching Yahoo Finance headlines for {ticker} from {start_dt.date()} to {end_dt.date()}...\")\n",
        "\n",
        "    all_articles = []\n",
        "\n",
        "    # --- FIX 2: Batch by month to overcome the ~100 results/request cap ---\n",
        "    current = start_dt\n",
        "    while current < end_dt:\n",
        "        # Compute the end of this batch window (1 month forward, capped at end_dt)\n",
        "        if current.month == 12:\n",
        "            next_month = datetime(current.year + 1, 1, 1)\n",
        "        else:\n",
        "            next_month = datetime(current.year, current.month + 1, 1)\n",
        "\n",
        "        batch_end = min(next_month, end_dt)\n",
        "\n",
        "        google_news = GNews(\n",
        "            language='en',\n",
        "            country='US',\n",
        "            start_date=(current.year, current.month, current.day),\n",
        "            end_date=(batch_end.year, batch_end.month, batch_end.day),\n",
        "            max_results=100\n",
        "        )\n",
        "\n",
        "        # --- FIX 1: Drop site: operator — it doesn't work in GNews.\n",
        "        #     Instead, fetch broadly and filter for Yahoo Finance below. ---\n",
        "        query = f\"{ticker} stock\"\n",
        "\n",
        "        try:\n",
        "            articles = google_news.get_news(query)\n",
        "            if articles:\n",
        "                all_articles.extend(articles)\n",
        "                print(f\"  {current.strftime('%Y-%m')}: fetched {len(articles)} articles\")\n",
        "            else:\n",
        "                print(f\"  {current.strftime('%Y-%m')}: no results\")\n",
        "        except Exception as e:\n",
        "            print(f\"  {current.strftime('%Y-%m')}: error — {e}\")\n",
        "\n",
        "        current = batch_end\n",
        "        time.sleep(1)  # be polite to the API\n",
        "\n",
        "    if not all_articles:\n",
        "        print(\"No articles found across the entire date range.\")\n",
        "        return pd.DataFrame()\n",
        "\n",
        "    df = pd.DataFrame(all_articles)\n",
        "\n",
        "    if not df.empty:\n",
        "        df = df[['title', 'published date', 'url', 'publisher']].copy()\n",
        "        df.rename(columns={'published date': 'date'}, inplace=True)\n",
        "\n",
        "        # --- FIX 1 (continued): Filter to Yahoo Finance articles only.\n",
        "        #     'publisher' is a dict like {'href': '...', 'title': 'Yahoo Finance'} ---\n",
        "        def is_yahoo(row):\n",
        "            url_match = isinstance(row['url'], str) and 'yahoo' in row['url'].lower()\n",
        "            pub = row['publisher']\n",
        "            pub_match = isinstance(pub, dict) and 'yahoo' in pub.get('title', '').lower()\n",
        "            return url_match or pub_match\n",
        "\n",
        "        df = df[df.apply(is_yahoo, axis=1)].copy()\n",
        "\n",
        "        if df.empty:\n",
        "            print(\"Articles were fetched but none were from Yahoo Finance.\")\n",
        "            return pd.DataFrame()\n",
