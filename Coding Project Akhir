        "\"\"\"\n",
        "Direction Prediction Pipeline\n",
        "==============================\n",
        "Time-series classification with exogenous features.\n",
        "Uses a direct multi-step strategy: one LightGBM model per forecast horizon (1..10).\n",
        "\"\"\"\n",
        "\n",
        "import pandas as pd\n",
        "import numpy as np\n",
        "from lightgbm import LGBMClassifier\n",
        "from sklearn.model_selection import TimeSeriesSplit\n",
        "from sklearn.metrics import accuracy_score, roc_auc_score, classification_report\n",
        "from sklearn.preprocessing import StandardScaler\n",
        "import warnings\n",
        "warnings.filterwarnings(\"ignore\")\n",
        "\n",
        "# ─── 1. LOAD ──────────────────────────────────────────────────────────────────\n",
        "df = pd.read_csv(\"df.csv\", parse_dates=[\"date\"])\n",
        "df = df.sort_values(\"date\").reset_index(drop=True)\n",
        "\n",
        "print(f\"Loaded: {df.shape[0]} rows × {df.shape[1]} cols\")\n",
        "print(f\"Date range: {df['date'].min().date()} → {df['date'].max().date()}\")\n",
        "print(f\"direction distribution:\\n{df['direction'].value_counts()}\\n\")\n",
        "\n",
        "# ─── 2. FORWARD-FILL FUNDAMENTALS ─────────────────────────────────────────────\n",
        "# Quarterly fundamentals are sparse — propagate last known value forward\n",
        "price_cols  = [\"1. open\", \"2. high\", \"3. low\", \"5. volume\", \"direction\"]\n",
        "meta_cols   = [\"date\", \"reportedCurrency\", \"available_date_x\", \"available_date_y\"]\n",
        "fund_cols   = [c for c in df.columns if c not in price_cols + meta_cols]\n",
        "\n",
        "df[fund_cols] = df[fund_cols].ffill()\n",
        "\n",
        "# ─── 3. FEATURE ENGINEERING ───────────────────────────────────────────────────\n",
        "close = df[\"1. open\"]  # using open as proxy for close-of-prior-day\n",
        "\n",
        "# -- Price-based features\n",
        "for lag in [1, 2, 3, 5, 10, 20]:\n",
        "    df[f\"ret_{lag}d\"]    = close.pct_change(lag)\n",
        "    df[f\"lag_dir_{lag}\"] = df[\"direction\"].shift(lag)\n",
        "\n",
        "# Moving averages & distance\n",
        "for w in [5, 10, 20, 50]:\n",
        "    ma = close.rolling(w).mean()\n",
        "    df[f\"ma{w}_ratio\"] = close / ma - 1\n",
        "\n",
        "# Volatility\n",
        "df[\"vol_5d\"]  = close.pct_change().rolling(5).std()\n",
        "df[\"vol_20d\"] = close.pct_change().rolling(20).std()\n",
        "\n",
        "# Volume features\n",
        "df[\"vol_ratio_5d\"] = df[\"5. volume\"] / df[\"5. volume\"].rolling(5).mean()\n",
        "\n",
        "# High-Low range\n",
        "df[\"hl_range\"] = (df[\"2. high\"] - df[\"3. low\"]) / df[\"1. open\"]\n",
        "\n",
        "# RSI-14\n",
        "delta = close.diff()\n",
        "gain  = delta.clip(lower=0).rolling(14).mean()\n",
        "loss  = (-delta.clip(upper=0)).rolling(14).mean()\n",
        "df[\"rsi14\"] = 100 - 100 / (1 + gain / loss.replace(0, np.nan))\n",
        "\n",
        "# Fundamental ratios (non-null ones)\n",
        "useful_fund = [c for c in fund_cols if df[c].notna().mean() > 0.5]\n",
        "print(f\"Fundamental features with >50% coverage: {len(useful_fund)}\")\n",
        "\n",
        "# ─── 4. DEFINE FEATURE SET ────────────────────────────────────────────────────\n",
        "price_features = [\n",
        "    *[f\"ret_{l}d\"    for l in [1,2,3,5,10,20]],\n",
        "    *[f\"lag_dir_{l}\" for l in [1,2,3,5,10,20]],\n",
        "    *[f\"ma{w}_ratio\" for w in [5,10,20,50]],\n",
        "    \"vol_5d\", \"vol_20d\", \"vol_ratio_5d\", \"hl_range\", \"rsi14\",\n",
        "]\n",
        "all_features = price_features + useful_fund\n",
        "df_feat = df[[\"date\", \"direction\"] + all_features].dropna()\n",
        "print(f\"After dropna: {len(df_feat)} rows with {len(all_features)} features\\n\")\n",
        "\n",
        "# ─── 5. DIRECT MULTI-STEP STRATEGY ───────────────────────────────────────────\n",
        "# For each horizon h (1..10), shift the target back by h days\n",
        "# so each model learns: \"given today's features, predict direction h days ahead\"\n",
        "\n",
        "HORIZONS   = list(range(1, 11))\n",
        "N_SPLITS   = 5\n",
        "results    = {}\n",
        "models     = {}\n",
        "\n",
        "print(\"=\" * 60)\n",
        "print(\"Training one LightGBM per horizon (TimeSeriesSplit CV)\")\n",
        "print(\"=\" * 60)\n",
        "\n",
        "for h in HORIZONS:\n",
        "    # Target: direction h steps into the future\n",
        "    y = df_feat[\"direction\"].shift(-h).dropna()\n",
        "    X = df_feat[all_features].iloc[:len(y)]\n",
        "\n",
        "    tscv = TimeSeriesSplit(n_splits=N_SPLITS)\n",
        "    fold_accs, fold_aucs = [], []\n",
        "\n",
        "    for train_idx, val_idx in tscv.split(X):\n",
        "        X_tr, X_val = X.iloc[train_idx], X.iloc[val_idx]\n",
        "        y_tr, y_val = y.iloc[train_idx], y.iloc[val_idx]\n",
        "\n",
        "        model = LGBMClassifier(\n",
        "            n_estimators=300,\n",
        "            learning_rate=0.05,\n",
        "            max_depth=5,\n",
        "            num_leaves=31,\n",
        "            subsample=0.8,\n",
        "            colsample_bytree=0.7,\n",
        "            class_weight=\"balanced\",\n",
        "            random_state=42,\n",
        "            verbose=-1,\n",
        "        )\n",
        "        model.fit(X_tr, y_tr,\n",
        "                  eval_set=[(X_val, y_val)],\n",
        "                  callbacks=[])\n",
        "\n",
        "        preds  = model.predict(X_val)\n",
        "        probas = model.predict_proba(X_val)[:, 1]\n",
        "        fold_accs.append(accuracy_score(y_val, preds))\n",
        "        fold_aucs.append(roc_auc_score(y_val, probas))\n",
        "\n",
        "    # Retrain on full data for final predictions\n",
        "    final_model = LGBMClassifier(\n",
        "        n_estimators=300, learning_rate=0.05, max_depth=5,\n",
        "        num_leaves=31, subsample=0.8, colsample_bytree=0.7,\n",
        "        class_weight=\"balanced\", random_state=42, verbose=-1,\n",
        "    )\n",
        "    final_model.fit(X, y)\n",
        "    models[h] = final_model\n",
        "\n",
        "    results[h] = {\n",
        "        \"acc_mean\": np.mean(fold_accs),\n",
        "        \"acc_std\":  np.std(fold_accs),\n",
        "        \"auc_mean\": np.mean(fold_aucs),\n",
        "        \"auc_std\":  np.std(fold_aucs),\n",
        "    }\n",
        "    print(f\"  h={h:2d} | Accuracy: {np.mean(fold_accs):.3f} ±{np.std(fold_accs):.3f} \"\n",
        "          f\"| AUC: {np.mean(fold_aucs):.3f} ±{np.std(fold_aucs):.3f}\")\n",
        "\n",
        "# ─── 6. PREDICT NEXT 10 DAYS ──────────────────────────────────────────────────\n",
        "print(\"\\n\" + \"=\" * 60)\n",
        "print(\"PREDICTIONS FOR NEXT 10 TRADING DAYS\")\n",
        "print(\"=\" * 60)\n",
        "\n",
        "last_row = df_feat[all_features].iloc[[-1]]\n",
        "last_date = df_feat[\"date\"].iloc[-1]\n",
        "\n",
        "# Generate approximate future dates (skip weekends)\n",
        "future_dates = pd.bdate_range(start=last_date + pd.Timedelta(days=1), periods=10)\n",
        "\n",
        "predictions = []\n",
        "for h in HORIZONS:\n",
        "    model   = models[h]\n",
        "    proba   = model.predict_proba(last_row)[0, 1]\n",
        "    pred    = int(proba >= 0.5)\n",
        "    conf    = max(proba, 1 - proba)\n",
        "    predictions.append({\n",
        "        \"day\":       h,\n",
        "        \"date\":      future_dates[h - 1].date(),\n",
        "        \"direction\": pred,\n",
        "        \"label\":     \"UP ↑\" if pred == 1 else \"DOWN ↓\",\n",
        "        \"prob_up\":   round(proba, 3),\n",
        "        \"confidence\":round(conf, 3),\n",
        "        \"cv_acc\":    round(results[h][\"acc_mean\"], 3),\n",
        "        \"cv_auc\":    round(results[h][\"auc_mean\"], 3),\n",
        "    })\n",
        "\n",
        "pred_df = pd.DataFrame(predictions)\n",
        "print(pred_df.to_string(index=False))\n",
        "\n",
        "# ─── 7. FEATURE IMPORTANCE (h=1 model) ───────────────────────────────────────\n",
        "print(\"\\n--- Top 15 Features (h=1 model) ---\")\n",
        "fi = pd.Series(models[1].feature_importances_, index=all_features)\n",
        "print(fi.nlargest(15).to_string())"
      ],
