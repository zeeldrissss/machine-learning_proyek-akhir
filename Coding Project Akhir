        "import pandas as pd\n",
        "import numpy as np\n",
        "\n",
        "from vaderSentiment.vaderSentiment import SentimentIntensityAnalyzer\n",
        "from sklearn.feature_extraction.text import TfidfVectorizer\n",
        "from sklearn.decomposition import TruncatedSVD\n",
        "from sklearn.preprocessing import normalize\n",
        "from lightgbm import LGBMClassifier\n",
        "from sklearn.metrics import (\n",
        "    confusion_matrix, classification_report,\n",
        "    accuracy_score, roc_auc_score, brier_score_loss\n",
        ")\n",
        "import warnings\n",
        "warnings.filterwarnings(\"ignore\")\n",
        "\n",
        "# ─── 1. LOAD PRICE DATA ───────────────────────────────────────────────────────\n",
        "df = pd.read_csv(\"df.csv\", parse_dates=[\"date\"])\n",
        "df = df.sort_values(\"date\").reset_index(drop=True)\n",
        "\n",
        "# ─── 2. LOAD & CLEAN NEWS DATA ────────────────────────────────────────────────\n",
        "news = pd.read_csv(\"GOOGL_yahoo_news_2023_2025.csv\")\n",
        "news[\"date\"] = pd.to_datetime(news[\"date\"], utc=True).dt.tz_localize(None).dt.normalize()\n",
        "news = news.dropna(subset=[\"title\"]).reset_index(drop=True)\n",
        "print(f\"News: {len(news)} headlines across {news['date'].nunique()} unique dates\")\n",
        "print(f\"Coverage: {news['date'].min().date()} → {news['date'].max().date()}\")\n",
        "\n",
        "# ─── 3. VADER SENTIMENT SCORES ────────────────────────────────────────────────\n",
        "vader = SentimentIntensityAnalyzer()\n",
        "\n",
        "def vader_scores(text):\n",
        "    s = vader.polarity_scores(str(text))\n",
        "    return [s[\"pos\"], s[\"neg\"], s[\"neu\"], s[\"compound\"]]\n",
        "\n",
        "vader_matrix = np.array([vader_scores(t) for t in news[\"title\"]])\n",
        "VADER_COLS = [\"vader_pos\", \"vader_neg\", \"vader_neu\", \"vader_compound\"]\n",
        "print(f\"\\nVADER scored {len(vader_matrix)} headlines\")\n",
        "print(f\"Mean compound: {vader_matrix[:, 3].mean():.3f}  \"\n",
        "      f\"Std: {vader_matrix[:, 3].std():.3f}\")\n",
        "\n",
        "# ─── 4. TF-IDF + LSA SEMANTIC EMBEDDINGS ─────────────────────────────────────\n",
        "# Finance-aware stop words + standard stop words\n",
        "finance_stop = [\n",
        "    \"stock\", \"shares\", \"google\", \"alphabet\", \"googl\", \"company\",\n",
        "    \"says\", \"said\", \"will\", \"new\", \"year\", \"just\", \"market\",\n",
        "    \"the\", \"a\", \"an\", \"in\", \"of\", \"to\", \"for\", \"on\", \"at\", \"is\",\n",
        "    \"are\", \"was\", \"be\", \"by\", \"with\", \"its\", \"it\", \"from\", \"has\", \"have\"\n",
        "]\n",
        "\n",
        "tfidf = TfidfVectorizer(\n",
        "    max_features=500,\n",
        "    ngram_range=(1, 2),\n",
        "    min_df=2,\n",
        "    stop_words=finance_stop,\n",
        "    sublinear_tf=True,\n",
        ")\n",
        "tfidf_matrix = tfidf.fit_transform(news[\"title\"].tolist())\n",
        "\n",
        "N_COMPONENTS = 10\n",
        "svd = TruncatedSVD(n_components=N_COMPONENTS, random_state=42)\n",
        "lsa_matrix = svd.fit_transform(tfidf_matrix)\n",
        "lsa_matrix = normalize(lsa_matrix, norm=\"l2\")   # unit-normalize each headline\n",
        "\n",
        "explained = svd.explained_variance_ratio_.sum()\n",
        "print(f\"\\nLSA ({N_COMPONENTS} components) explains \"\n",
        "      f\"{explained:.1%} of TF-IDF variance\")\n",
        "\n",
        "LSA_COLS = [f\"lsa_{i}\" for i in range(N_COMPONENTS)]\n",
        "\n",
        "# Combine into a single embedding DataFrame aligned with news rows\n",
        "news_embed = pd.DataFrame(\n",
        "    np.hstack([vader_matrix, lsa_matrix]),\n",
        "    columns=VADER_COLS + LSA_COLS\n",
        ")\n",
        "news_embed[\"date\"] = news[\"date\"].values\n",
        "EMB_DIM = len(VADER_COLS) + N_COMPONENTS   # 14\n",
        "\n",
        "print(f\"\\nEmbedding per headline: {EMB_DIM}-dimensional \"\n",
        "      f\"(4 VADER + {N_COMPONENTS} LSA)\")\n",
        "\n",
        "# ─── 5. EXPONENTIAL DECAY AGGREGATION ────────────────────────────────────────\n",
        "# For every trading day t, produce a decay-weighted mean embedding\n",
        "# using two half-lives to capture both recency and medium-term sentiment.\n",
        "\n",
        "LAMBDAS = {\"fast\": 0.15, \"slow\": 0.03}\n",
        "# fast: half-life = ln(2)/0.15 ≈ 4.6 days\n",
        "# slow: half-life = ln(2)/0.03 ≈ 23.1 days\n",
        "\n",
        "embed_cols  = VADER_COLS + LSA_COLS\n",
        "news_dates  = news_embed[\"date\"].values.astype(\"datetime64[D]\")\n",
        "news_vecs   = news_embed[embed_cols].values\n",
        "\n",
        "def decay_aggregate(target_date, lambda_):\n",
        "    \"\"\"\n",
        "    Compute exponentially-decayed weighted mean of all news\n",
        "    published ON OR BEFORE target_date.\n",
        "    Returns: (weighted_mean_vector [EMB_DIM], effective_news_count [1])\n",
        "    \"\"\"\n",
        "    target = np.datetime64(target_date, \"D\")\n",
        "    mask   = news_dates <= target\n",
        "    if not mask.any():\n",
        "        return np.zeros(EMB_DIM + 1)\n",
        "\n",
        "    deltas  = (target - news_dates[mask]).astype(float)   # days since each headline\n",
        "    weights = np.exp(-lambda_ * deltas)\n",
        "    w_sum   = weights.sum()\n",
        "\n",
        "    wmean   = (weights[:, None] * news_vecs[mask]).sum(axis=0) / w_sum\n",
        "    # Effective count: sum of weights (higher = more recent/more news)\n",
        "    eff_count = w_sum\n",
        "    return np.append(wmean, eff_count)\n",
        "\n",
        "print(\"\\nComputing exponential decay features for all trading days...\")\n",
        "trading_dates = df[\"date\"].values\n",
        "\n",
        "feature_rows = []\n",
        "for td in trading_dates:\n",
        "    row = {}\n",
        "    for name, lam in LAMBDAS.items():\n",
        "        vec = decay_aggregate(td, lam)\n",
        "        for i, col in enumerate(embed_cols):\n",
        "            row[f\"{name}_{col}\"] = vec[i]\n",
        "        row[f\"{name}_eff_count\"] = vec[-1]\n",
        "    feature_rows.append(row)\n",
        "\n",
        "news_features = pd.DataFrame(feature_rows)\n",
        "news_features[\"date\"] = df[\"date\"].values\n",
        "print(f\"News feature matrix: {news_features.shape}  \"\n",
        "      f\"({len(news_features.columns)-1} sentiment features)\")\n",
        "\n",
        "# ─── 6. FORWARD-FILL FUNDAMENTALS & PRICE FEATURES ───────────────────────────\n",
        "price_cols = [\"1. open\", \"2. high\", \"3. low\", \"5. volume\", \"direction\"]\n",
        "meta_cols  = [\"date\", \"reportedCurrency\", \"available_date_x\", \"available_date_y\"]\n",
        "fund_cols  = [c for c in df.columns if c not in price_cols + meta_cols]\n",
        "df[fund_cols] = df[fund_cols].ffill()\n",
        "\n",
        "close = df[\"1. open\"]\n",
        "\n",
        "for lag in [1, 2, 3, 5, 10, 20]:\n",
        "    df[f\"ret_{lag}d\"]    = close.pct_change(lag)\n",
        "    df[f\"lag_dir_{lag}\"] = df[\"direction\"].shift(lag)\n",
        "\n",
        "for w in [5, 10, 20, 50]:\n",
        "    df[f\"ma{w}_ratio\"] = close / close.rolling(w).mean() - 1\n",
        "\n",
        "df[\"vol_5d\"]       = close.pct_change().rolling(5).std()\n",
        "df[\"vol_20d\"]      = close.pct_change().rolling(20).std()\n",
        "df[\"vol_ratio_5d\"] = df[\"5. volume\"] / df[\"5. volume\"].rolling(5).mean()\n",
        "df[\"hl_range\"]     = (df[\"2. high\"] - df[\"3. low\"]) / df[\"1. open\"]\n",
        "\n",
        "delta = close.diff()\n",
        "gain  = delta.clip(lower=0).rolling(14).mean()\n",
        "loss  = (-delta.clip(upper=0)).rolling(14).mean()\n",
        "df[\"rsi14\"] = 100 - 100 / (1 + gain / loss.replace(0, np.nan))\n",
        "\n",
        "useful_fund = [c for c in fund_cols if df[c].notna().mean() > 0.5]\n",
        "price_features = [\n",
        "    *[f\"ret_{l}d\"    for l in [1,2,3,5,10,20]],\n",
        "    *[f\"lag_dir_{l}\" for l in [1,2,3,5,10,20]],\n",
        "    *[f\"ma{w}_ratio\" for w in [5,10,20,50]],\n",
        "    \"vol_5d\", \"vol_20d\", \"vol_ratio_5d\", \"hl_range\", \"rsi14\",\n",
        "]\n",
        "\n",
        "# ─── 7. MERGE ALL FEATURES ────────────────────────────────────────────────────\n",
        "sentiment_feature_cols = [c for c in news_features.columns if c != \"date\"]\n",
        "df = df.merge(news_features, on=\"date\", how=\"left\")\n",
        "all_features = price_features + useful_fund + sentiment_feature_cols\n",
        "df_feat = df[[\"date\", \"direction\"] + all_features].dropna().reset_index(drop=True)\n",
        "\n",
        "print(f\"\\nFinal feature matrix: {df_feat.shape}\")\n",
        "print(f\"  Price+momentum : {len(price_features)}\")\n",
        "print(f\"  Fundamentals   : {len(useful_fund)}\")\n",
        "print(f\"  Sentiment      : {len(sentiment_feature_cols)}\")\n",
        "print(f\"  TOTAL          : {len(all_features)}\")\n",
        "\n",
        "# ─── 8. WALK-FORWARD VALIDATION ───────────────────────────────────────────────\n",
        "n    = len(df_feat)\n",
        "ROLL = 30\n",
        "\n",
        "print(f\"\\nWalk-forward: predicting rows {n-ROLL} → {n-1}  \"\n",
        "      f\"(min train = {n-ROLL} rows)\\n\")\n",
        "\n",
        "records = []\n",
        "for step in range(ROLL):\n",
        "    cutoff   = n - ROLL + step\n",
        "    pred_idx = cutoff + 1\n",
        "    if pred_idx >= n:\n",
        "        break\n",
        "\n",
        "    X_train = df_feat[all_features].iloc[:cutoff + 1]\n",
        "    y_train = df_feat[\"direction\"].iloc[:cutoff + 1]\n",
        "    X_pred  = df_feat[all_features].iloc[[pred_idx]]\n",
        "    y_true  = df_feat[\"direction\"].iloc[pred_idx]\n",
        "\n",
        "    model = LGBMClassifier(\n",
        "        n_estimators=300, learning_rate=0.05, max_depth=5,\n",
        "        num_leaves=31, subsample=0.8, colsample_bytree=0.7,\n",
        "        class_weight=\"balanced\", random_state=42, verbose=-1,\n",
        "    )\n",
        "    model.fit(X_train, y_train)\n",
        "\n",
        "    prob_up = model.predict_proba(X_pred)[0, 1]\n",
        "    pred    = int(prob_up >= 0.5)\n",
        "\n",
        "    records.append({\n",
        "        \"step\":    step + 1,\n",
        "        \"date\":    df_feat[\"date\"].iloc[pred_idx].date(),\n",
        "        \"y_true\":  int(y_true),\n",
        "        \"y_pred\":  pred,\n",
        "        \"prob_up\": round(prob_up, 4),\n",
        "        \"correct\": int(pred == y_true),\n",
        "    })\n",
        "\n",
        "    if (step + 1) % 5 == 0 or step == 0:\n",
        "        print(f\"  step {step+1:2d}/{ROLL} | {records[-1]['date']} \"\n",
        "              f\"| pred={'UP↑' if pred else 'DN↓'} \"\n",
        "              f\"| true={'UP↑' if y_true else 'DN↓'} \"\n",
        "              f\"| prob={prob_up:.3f}\")\n",
        "\n",
        "results_df = pd.DataFrame(records)\n",
        "\n",
        "# ─── 9. METRICS ───────────────────────────────────────────────────────────────\n",
        "y_true_all = results_df[\"y_true\"].values\n",
        "y_pred_all = results_df[\"y_pred\"].values\n",
        "prob_all   = results_df[\"prob_up\"].values\n",
        "\n",
        "tn, fp, fn, tp = confusion_matrix(y_true_all, y_pred_all).ravel()\n",
        "acc    = accuracy_score(y_true_all, y_pred_all)\n",
        "auc    = roc_auc_score(y_true_all, prob_all)\n",
        "brier  = brier_score_loss(y_true_all, prob_all)\n",
        "prec_1 = tp / (tp + fp) if (tp + fp) > 0 else 0\n",
        "rec_1  = tp / (tp + fn) if (tp + fn) > 0 else 0\n",
        "spec   = tn / (tn + fp) if (tn + fp) > 0 else 0\n",
        "\n",
        "print(\"\\n\" + \"=\" * 60)\n",
        "print(\"WALK-FORWARD EVALUATION — WITH SENTIMENT FEATURES\")\n",
        "print(\"=\" * 60)\n",
        "print(f\"\\nConfusion Matrix (rows=actual, cols=predicted):\")\n",
        "print(f\"                 Pred DOWN  Pred UP\")\n",
        "print(f\"  Actual DOWN  |   {tn:4d}    |  {fp:4d}  |\")\n",
        "print(f\"  Actual UP    |   {fn:4d}    |  {tp:4d}  |\")\n",
        "print(f\"\\n{classification_report(y_true_all, y_pred_all, target_names=['DOWN (0)', 'UP (1)'])}\")\n",
        "print(f\"  Accuracy        : {acc:.4f}\")\n",
        "print(f\"  ROC-AUC         : {auc:.4f}\")\n",
        "print(f\"  Brier Score     : {brier:.4f}  (baseline = 0.25)\")\n",
        "print(f\"  Precision (UP)  : {prec_1:.4f}\")\n",
        "print(f\"  Recall (UP)     : {rec_1:.4f}\")\n",
        "print(f\"  Specificity     : {spec:.4f}  (recall for DOWN)\")\n",
        "\n",
        "# ─── 10. FEATURE IMPORTANCE — SENTIMENT CONTRIBUTION ─────────────────────────\n",
        "# Retrain on full data to get final feature importance\n",
        "final_model = LGBMClassifier(\n",
        "    n_estimators=300, learning_rate=0.05, max_depth=5,\n",
        "    num_leaves=31, subsample=0.8, colsample_bytree=0.7,\n",
        "    class_weight=\"balanced\", random_state=42, verbose=-1,\n",
        ")\n",
        "final_model.fit(df_feat[all_features], df_feat[\"direction\"])\n",
        "fi = pd.Series(final_model.feature_importances_, index=all_features)\n",
        "\n",
        "print(\"\\n--- Top 20 Features (full-data model) ---\")\n",
        "print(fi.nlargest(20).to_string())\n",
        "\n",
        "sentiment_fi = fi[sentiment_feature_cols].sort_values(ascending=False)\n",
        "print(f\"\\n--- Sentiment Feature Importances ---\")\n",
        "print(sentiment_fi.to_string())\n",
        "\n",
        "# ─── 11. DAY-BY-DAY TABLE ─────────────────────────────────────────────────────\n",
        "results_df[\"true_lbl\"] = results_df[\"y_true\"].map({1:\"UP↑\", 0:\"DN↓\"})\n",
        "results_df[\"pred_lbl\"] = results_df[\"y_pred\"].map({1:\"UP↑\", 0:\"DN↓\"})\n",
        "results_df[\"✓\"]        = results_df[\"correct\"].map({1:\"✓\", 0:\"✗\"})\n",
        "print(\"\\nDay-by-day predictions:\")\n",
        "print(results_df[[\"step\",\"date\",\"true_lbl\",\"pred_lbl\",\"prob_up\",\"✓\"]].to_string(index=False))"
      ],
