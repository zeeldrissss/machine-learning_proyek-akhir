        "# Rename overlapping columns before merging\n",
        "inc_stmt = inc_stmt.rename(columns={'netIncome': 'netIncome_IS'})\n",
        "cf_stmt = cf_stmt.rename(columns={'netIncome': 'netIncome_CF'})\n",
        "\n",
        "# Drop 'reportedCurrency' from CF and BS since it's identical across all three\n",
        "cf_stmt = cf_stmt.drop(columns=['reportedCurrency'])\n",
        "bal_sheet = bal_sheet.drop(columns=['reportedCurrency'])\n",
        "\n",
        "# Add 1 day to make the data \"available\" the day after the quarter ends\n",
        "inc_stmt['available_date'] = inc_stmt['fiscalDateEnding'] + pd.Timedelta(days=1)\n",
        "cf_stmt['available_date'] = cf_stmt['fiscalDateEnding'] + pd.Timedelta(days=1)\n",
        "bal_sheet['available_date'] = bal_sheet['fiscalDateEnding'] + pd.Timedelta(days=1)\n",
        "\n",
        "# merge_asof requires the \"on\" key to be sorted\n",
        "# Join Income Statement\n",
        "merged_data = pd.merge_asof(\n",
        "    prices,\n",
        "    inc_stmt.drop(columns=['fiscalDateEnding']),\n",
        "    left_on='date',\n",
        "    right_on='available_date',\n",
        "    direction='backward' # Takes the closest available_date <= the price date\n",
        ")\n",
        "\n",
        "# Join Cash Flow Statement\n",
        "merged_data = pd.merge_asof(\n",
        "    merged_data,\n",
        "    cf_stmt.drop(columns=['fiscalDateEnding']),\n",
        "    left_on='date',\n",
        "    right_on='available_date',\n",
        "    direction='backward'\n",
        ")\n",
        "\n",
        "# Join Balance Sheet\n",
        "merged_data = pd.merge_asof(\n",
        "    merged_data,\n",
        "    bal_sheet.drop(columns=['fiscalDateEnding']),\n",
        "    left_on='date',\n",
        "    right_on='available_date',\n",
        "    direction='backward'\n",
        ")\n",
        "\n",
        "# Drop the redundant available_date columns if desired\n",
        "merged_data = merged_data.drop(columns=['available_date'])"
      ],
